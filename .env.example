# ===== pepsistreamy 설정 =====
# 이 파일을 .env 로 복사해서 채우세요.  (.env 는 절대 공개/커밋 금지 — 봇 토큰은 비밀번호입니다)
#   PowerShell:  Copy-Item .env.example .env
# 이 .env.example 자체에는 절대 본인 토큰을 넣지 마세요(공유용 빈 템플릿입니다).

# [필수] 디스코드 봇 토큰  (각자 자기 봇을 만들어 자기 토큰을 넣습니다)
# Discord 개발자 포털 > Applications > (앱) > Bot > Reset Token
DISCORD_TOKEN=

# [선택] 슬래시 명령을 즉시 동기화할 서버(길드) ID.
# 비워두면 전역 동기화(최대 1시간 뒤 명령이 보임). 디스코드 개발자모드 켜고 서버 우클릭 > ID 복사.
DISCORD_GUILD_ID=

# [선택] 캡처할 장치 이름의 일부(부분일치).
#  - 비워두면 = 시스템 기본 스피커의 전체 믹스(루프백). 백그라운드/최소화 탭 포함 모두 캡처.
#  - 특정 탭만 분리하려면 가상 케이블 출력장치 이름 일부(예: CABLE Output). README 참고.
YTCAST_DEVICE=
