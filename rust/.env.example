# ===== pepsistreamy (Rust) 설정 =====
# 이 파일을 .env 로 복사해 채우세요. .env 는 절대 공개/커밋 금지(봇 토큰은 비밀번호).
#   PowerShell:  Copy-Item .env.example .env
# 실행파일과 같은 폴더(또는 상위 폴더)의 .env 를 자동으로 읽습니다.

# [필수] 디스코드 봇 토큰 (Discord 개발자 포털 > Bot > Reset Token)
DISCORD_TOKEN=

# [선택] 슬래시 명령 즉시 동기화할 서버(길드) ID. 비우면 전역(최대 1시간).
DISCORD_GUILD_ID=

# ----- 캡처 소스 (우선순위: PROCESS > DEVICE > 기본 스피커) -----

# [선택] 특정 앱만 캡처: PID 또는 프로세스명(부분일치). 추가 설치 불필요(권장).
#  예: chrome  (크롬은 모든 탭을 한 오디오 프로세스에서 섞으므로 단일 탭만 분리하려면
#      그 탭을 전용 브라우저/프로필에 띄우세요.) `pepsistreamy processes` 로 목록 확인.
YTCAST_PROCESS=

# [선택] 특정 출력장치 캡처: 이름 일부(부분일치). 가상 케이블(예: CABLE) 분리에 사용.
YTCAST_DEVICE=

# ----- 내장 DSP (배경음을 앰비언트하게 + 목소리와 덜 겹치게) -----
# YTCAST_DSP: off(기본) | on | ambient
#   ambient 프리셋: HP120Hz, LP1000Hz, reverb0.35, room0.7, gain0.55
#   세부 덮어쓰기: YTCAST_HP / YTCAST_LP (Hz, 0=off), YTCAST_REVERB / YTCAST_ROOM (0~1), YTCAST_GAIN
YTCAST_DSP=
YTCAST_HP=
YTCAST_LP=
YTCAST_REVERB=
YTCAST_ROOM=
YTCAST_GAIN=
